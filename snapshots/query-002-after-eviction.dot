digraph ORAMTree {
  graph [rankdir=TB, splines=line, nodesep=0.45, ranksep=0.75];
  node [shape=box, style="rounded,filled", fontname="Menlo", fontsize=10];
  edge [color="#555555"];
  labelloc="t";
  label="After eviction/write-back | logical block 3 | old leaf 5 | new leaf 3 | path [1, 3, 6, 13] | stash size 0";

  b1 [label="bucket 1\\nB3@L3 | D", fillcolor="#ffe599", color="#cc0000", penwidth="3"];
  b2 [label="bucket 2\\nD | D", fillcolor="#f3f4f6", color="#555555", penwidth="1"];
  b3 [label="bucket 3\\nD | D", fillcolor="#ffe599", color="#cc0000", penwidth="3"];
  b4 [label="bucket 4\\nD | D", fillcolor="#f3f4f6", color="#555555", penwidth="1"];
  b5 [label="bucket 5\\nD | D", fillcolor="#f3f4f6", color="#555555", penwidth="1"];
  b6 [label="bucket 6\\nD | D", fillcolor="#ffe599", color="#cc0000", penwidth="3"];
  b7 [label="bucket 7\\nB5@L6 | D", fillcolor="#f3f4f6", color="#555555", penwidth="1"];
  b8 [label="bucket 8\\nB2@L0 | D", fillcolor="#f3f4f6", color="#555555", penwidth="1"];
  b9 [label="bucket 9\\nD | D", fillcolor="#f3f4f6", color="#555555", penwidth="1"];
  b10 [label="bucket 10\\nD | D", fillcolor="#f3f4f6", color="#555555", penwidth="1"];
  b11 [label="bucket 11\\nD | D", fillcolor="#f3f4f6", color="#555555", penwidth="1"];
  b12 [label="bucket 12\\nB6@L4 | D", fillcolor="#f3f4f6", color="#555555", penwidth="1"];
  b13 [label="bucket 13\\nD | D", fillcolor="#ffe599", color="#cc0000", penwidth="3"];
  b14 [label="bucket 14\\nB0@L6 | B1@L6", fillcolor="#f3f4f6", color="#555555", penwidth="1"];
  b15 [label="bucket 15\\nB4@L7 | B7@L7", fillcolor="#f3f4f6", color="#555555", penwidth="1"];

  b1 -> b2;
  b1 -> b3;
  b2 -> b4;
  b2 -> b5;
  b3 -> b6;
  b3 -> b7;
  b4 -> b8;
  b4 -> b9;
  b5 -> b10;
  b5 -> b11;
  b6 -> b12;
  b6 -> b13;
  b7 -> b14;
  b7 -> b15;

  { rank=same; b1; }
  { rank=same; b2; b3; }
  { rank=same; b4; b5; b6; b7; }
  { rank=same; b8; b9; b10; b11; b12; b13; b14; b15; }
}